# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to GitHub — it is in .gitignore.

# Supabase connection string (from Supabase dashboard → Settings → Database → Connection string → URI)
DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Optional: leave blank to use SQLite locally
# DATABASE_URL = ""
